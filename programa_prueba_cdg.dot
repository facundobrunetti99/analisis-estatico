digraph CDG {
  node [shape=box, fontname="Courier"];
  B0 [label="ENTRY", style=filled, fillcolor=lightblue];
  B9 [label="a = 1"];
  B8 [label="b = 2"];
  B6 [label="while (a)"];
  B7 [label="b = b + a"];
  B5 [label="if (b)"];
  B3 [label="c = b + 1"];
  B4 [label="c = a + b"];
  B2 [label="return c"];
  B1 [label="EXIT", style=filled, fillcolor=lightyellow];

  B0 -> B9 [style=dashed, color=red];
  B0 -> B8 [style=dashed, color=red];
  B6 -> B6 [style=dashed, color=red];
  B6 -> B7 [style=dashed, color=red];
  B0 -> B5 [style=dashed, color=red];
  B5 -> B3 [style=dashed, color=red];
  B5 -> B4 [style=dashed, color=red];
  B0 -> B2 [style=dashed, color=red];
}
